#!/bin/sh

IMG="soc-lab:1"
CTX="/root/soc-lab"

# build immagine se non esiste
if ! docker image inspect "$IMG" >/dev/null 2>&1; then
  echo "[HOST] Building image $IMG from $CTX ..."
  docker build -t "$IMG" "$CTX" || exit 1
fi

# run interattivo: dentro parte lab-launcher (menu persistente)
exec docker run --rm -it "$IMG"